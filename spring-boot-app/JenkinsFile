pipeline {
    agent {
        docker {

          image 'shyam1239/maven-docker-agent:v2'
          args '--user root -v /var/run/docker.sock:/var/run/docker.sock' // mount Docker socket to access the host's Docker daemon
        }
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/Syamlal-M/javaplication-cicd.git'
            }
        }
   
       stage('Check Docker Version') {
        steps {
         sh '''
         which docker
         docker version
         docker --version
         '''
    }
}

       }
    }

