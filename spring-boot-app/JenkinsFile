pipeline {
    agent {
        docker {
         image 'maven:3.9.11-eclipse-temurin-17'
         args '-v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/Syamlal-M/javaplication-cicd.git'
            }
        }
   
       stage('Check Docker Version') {
        steps {
         sh '''
         which docker
         docker version
         docker --version
         '''
    }
}

       }
    }

